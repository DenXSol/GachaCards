{
  "outputDirectory": "public",
  "cleanUrls": true,
  "redirects": [
    { "source": "/whos-that-pokemon.html", "destination": "/", "permanent": true },
    { "source": "/whos-that-pokemon", "destination": "/", "permanent": true }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
